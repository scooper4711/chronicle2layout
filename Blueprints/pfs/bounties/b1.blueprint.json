{
  "id": "pfs2.b1",
  "parent": "pfs2",
  "description": "#B1: The Whitefang Wyrm",
  "parameters": {
    "Event Info": {
      "event": {
        "type": "text",
        "description": "Event name",
        "example": "PaizoCon"
      },
      "eventcode": {
        "type": "text",
        "description": "Event code",
        "example": 1234
      },
      "date": {
        "type": "text",
        "description": "The date on which the game session took place",
        "example": "27.06.2020"
      },
      "gmid": {
        "type": "text",
        "description": "Gamemasters PFS ID",
        "example": 654321
      }
    },
    "Player Info": {
      "char": {
        "type": "text",
        "description": "Players character name",
        "example": "Stormageddon"
      },
      "societyid": {
        "type": "societyid",
        "description": "Pathfinder Society ID",
        "example": "123456-2001"
      }
    },
    "Rewards": {
      "starting_xp": {
        "type": "text",
        "description": "Starting XP",
        "example": 2
      },
      "xp_gained": {
        "type": "text",
        "description": "XP Gained",
        "example": 4
      },
      "total_xp": {
        "type": "text",
        "description": "Total XP",
        "example": 6
      },
      "starting_gp": {
        "type": "text",
        "description": "Starting GP",
        "example": "1cp"
      },
      "treasure_bundles_gp": {
        "type": "text",
        "description": "Gold from treasure bundles",
        "example": 23
      },
      "income_earned": {
        "type": "text",
        "description": "Income earned (gp)",
        "example": 1.8
      },
      "gp_gained": {
        "type": "text",
        "description": "GP Gained",
        "example": "4gp 2sp"
      },
      "gp_spent": {
        "type": "text",
        "description": "GP Spent",
        "example": "5sp"
      },
      "total_gp": {
        "type": "text",
        "description": "Total GP",
        "example": "3gp 7sp 1cp"
      }
    },
    "Checkboxes, Reputation and Items": {
      "summary_checkbox": {
        "type": "choice",
        "description": "Checkboxes in the adventure summary that should be selected",
        "choices": [1, 2, 3, 4, 5],
        "example": "1,2,3,4,5"
      },
      "reputation": {
        "type": "multiline",
        "description": "Reputation Gained",
        "example": "Grand Archive: +4",
        "lines": 3
      },
      "strikeout_item_lines": {
        "type": "choice",
        "description": "Item line numbers that should be struk out",
        "choices": [1, 2, 3, 4, 5, 6, 7, 8, 9],
        "example": "1,2,3,4,5,6,7,8,9"
      }
    },
    "Notes": {
      "notes": {
        "type": "multiline",
        "description": "Notes on the chronicle sheet",
        "example": "This is a player note",
        "lines": 12
      }
    }
  },
  "field_styles": {
    "defaultfont": {
      "font": "Helvetica",
      "fontsize": 14
    }
  },
  "fields": [
    {
      "name": "event",
      "param": "event",
      "type": "text",
      "canvas": "session_info",
      "styles": ["defaultfont"],
      "align": "LB",
      "left": "@h_rule[0].left",
      "right": "@h_rule[0].right",
      "bottom": "@h_rule[0]"
    },
    {
      "name": "eventcode",
      "param": "eventcode",
      "type": "text",
      "canvas": "session_info",
      "styles": ["defaultfont"],
      "align": "LB",
      "left": "@h_rule[2].left",
      "right": "@h_rule[2].right",
      "bottom": "@h_rule[2]"
    },
    {
      "name": "date",
      "param": "date",
      "type": "text",
      "canvas": "session_info",
      "styles": ["defaultfont"],
      "align": "CB",
      "left": "@h_rule[3].left",
      "right": "@h_rule[3].right",
      "bottom": "@h_rule[3]"
    },
    {
      "name": "gmid",
      "param": "gmid",
      "type": "text",
      "canvas": "session_info",
      "styles": ["defaultfont"],
      "align": "CB",
      "left": "@h_rule[1].left",
      "right": "@h_rule[1].right",
      "bottom": "@h_rule[1]"
    },
    {
      "name": "char",
      "param": "char",
      "type": "text",
      "canvas": "character_info",
      "styles": ["defaultfont"],
      "fontweight": "bold",
      "align": "LB",
      "left": "@h_rule[1].left",
      "right": "@h_rule[1].right",
      "bottom": "@h_rule[1]"
    },
    {
      "name": "societyid_player",
      "param": "societyid.player",
      "type": "text",
      "canvas": "character_info",
      "trigger": "societyid",
      "styles": ["defaultfont"],
      "fontsize": 9,
      "fontweight": "bold",
      "align": "RM",
      "left": "@h_rule[2].left",
      "right": "@h_rule[2].right",
      "bottom": "@h_rule[2]"
    },
    {
      "name": "societyid_dash",
      "value": "-",
      "type": "text",
      "canvas": "character_info",
      "trigger": "societyid",
      "styles": ["defaultfont"],
      "fontsize": 9,
      "fontweight": "bold",
      "align": "CM",
      "left": "@h_rule[2].right",
      "right": "@h_rule[3].left",
      "bottom": "@h_rule[3]"
    },
    {
      "name": "societyid_char",
      "param": "societyid.char_without_first_digit",
      "type": "text",
      "canvas": "character_info",
      "trigger": "societyid",
      "styles": ["defaultfont"],
      "fontsize": 9,
      "fontweight": "bold",
      "align": "LM",
      "left": "@h_rule[3].left + 1em",
      "right": "@h_rule[3].right",
      "bottom": "@h_rule[3]"
    },
    {
      "name": "xp_gained",
      "param": "xp_gained",
      "type": "text",
      "canvas": "rewards",
      "styles": ["defaultfont"],
      "align": "CM",
      "left": "@grey_box[0].left",
      "right": "@grey_box[0].right",
      "top": "@grey_box[0].bottom",
      "bottom": "@grey_box[1].top"
    },
    {
      "name": "gp_gained",
      "param": "gp_gained",
      "type": "text",
      "canvas": "rewards",
      "styles": ["defaultfont"],
      "align": "CM",
      "left": "@grey_box[3].left",
      "right": "@grey_box[3].right",
      "top": "@grey_box[3].bottom",
      "bottom": "@grey_box[4].top"
    }
  ],
  "canvases": [
    {
      "name": "main",
      "parent": "page",
      "left": "v_bar[0]",
      "right": "v_thin[2]",
      "top": "h_thin[2]",
      "bottom": "h_thin[8]"
    },
    {
      "name": "character_info",
      "parent": "main",
      "left": "main.left",
      "right": "v_thin[1]",
      "top": "main.top",
      "bottom": "h_bar[0]"
    },
    {
      "name": "reputation",
      "parent": "main",
      "left": "character_info.right",
      "right": "main.right",
      "top": "main.top",
      "bottom": "h_bar[0]"
    },
    {
      "name": "summary",
      "parent": "main",
      "left": "main.left",
      "right": "main.right",
      "top": "h_bar[0]",
      "bottom": "h_bar[1]"
    },
    {
      "name": "items",
      "parent": "main",
      "left": "v_bar[0]",
      "right": "v_thin[0]",
      "top": "h_bar[1]",
      "bottom": "h_bar[2]"
    },
    {
      "name": "rewards",
      "parent": "main",
      "left": "v_bar[1]",
      "right": "main.right",
      "top": "h_bar[1]",
      "bottom": "h_thin[7]"
    },
    {
      "name": "notes",
      "parent": "main",
      "left": "main.left",
      "right": "rewards.left",
      "top": "items.bottom",
      "bottom": "rewards.bottom"
    },
    {
      "name": "session_info",
      "parent": "main",
      "left": "main.left",
      "right": "main.right",
      "top": "notes.bottom",
      "bottom": "main.bottom"
    }
  ]
}
